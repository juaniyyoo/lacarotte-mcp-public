{
  "name": "lacarotte-mcp",
  "version": "1.3.0",
  "description": "Serveur MCP LaCarotte — Expose le catalogue de produits locaux en circuits courts aux agents IA",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4",
    "mongodb": "^6.16.0",
    "jsonwebtoken": "^9.0.2",
    "@upstash/redis": "^1.34.8",
    "nanoid": "^5.1.5",
    "node-cron": "^3.0.3",
    "express": "^5.1.0",
    "undici": "^7.10.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.3",
    "@types/node": "^22.16.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/express": "^5.0.3",
    "tsx": "^4.20.3"
  },
  "author": "LaCarotte <tech@la-carotte.fr>",
  "license": "ISC"
}
