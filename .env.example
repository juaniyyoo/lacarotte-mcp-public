# ═══════════════════════════════════════════
# API LaCarotte
# ═══════════════════════════════════════════
LACAROTTE_API_URL=https://api.lacarotte.fr
LACAROTTE_PRIVATE_KEY=xxx
LACAROTTE_DEFAULT_TENANT=.fr.la-carotte
LACAROTTE_SERVER_CLIENT_ID=lacarotte-mcp

# ═══════════════════════════════════════════
# Base de données MCP
# ═══════════════════════════════════════════
MONGODB_URI=mongodb+srv://...
MONGODB_DB_NAME=lacarotte

# ═══════════════════════════════════════════
# Cache & Rate Limiting
# ═══════════════════════════════════════════
UPSTASH_REDIS_URL=xxx
UPSTASH_REDIS_TOKEN=xxx

# ═══════════════════════════════════════════
# Email (Brevo)
# ═══════════════════════════════════════════
BREVO_API_KEY=xxx
BREVO_SENDER_EMAIL=bonjour@lacarotte.fr
BREVO_SENDER_NAME=LaCarotte

# ═══════════════════════════════════════════
# SMS
# ═══════════════════════════════════════════
SMS_PROVIDER=ovh
SMS_API_KEY=xxx
SMS_API_SECRET=xxx
SMS_SENDER=LaCarotte

# ═══════════════════════════════════════════
# Claude API (synthèse hebdo SF-11)
# ═══════════════════════════════════════════
ANTHROPIC_API_KEY=xxx

# ═══════════════════════════════════════════
# Serveur MCP
# ═══════════════════════════════════════════
MCP_SERVER_PORT=3001
MCP_TRANSPORT=sse
NODE_ENV=development

# ═══════════════════════════════════════════
# Pré-lancement
# ═══════════════════════════════════════════
LAUNCH_DATE=2026-03-21T08:00:00+01:00
